# ─────────────────────────────────────────────────────────────
# Currere Frontend — Environment Variables (example)
# Copy this file to `.env.local` and adjust the values.
# `.env.local` is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# Base URL of the Currere backend API (without a trailing slash).
# The frontend appends `/api` and `/syncHub` to this value.
# Defaults to http://localhost:5279 when unset (local development).
NEXT_PUBLIC_API_URL=http://localhost:5279
